# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Google ADK Agent Models
HIGH_QUALITY_AGENT_MODEL=gemini-3.1-pro-preview
QUICK_AGENT_MODEL=gemini-3-flash-preview
IMAGE_ANALYSIS_MODEL=gemini-3-flash-preview

# Google Sheets/Docs Service Account
# For deployment, use SOMMELIER_SECRET_NAME (Secret Manager secret name)
# For local development, use SOMMELIER_CREDENTIALS (file path)
SOMMELIER_SECRET_NAME=your-secret-name
# SOMMELIER_CREDENTIALS=path/to/service-account-key.json

# Spreadsheet and Document IDs
SOMMELIER_CELLAR_SSID=your-cellar-spreadsheet-id
SOMMELIER_CONSUMED_SSID=your-consumed-wines-spreadsheet-id
SOMMELIER_TASTING_NOTES_SSID=your-tasting-notes-spreadsheet-id
SOMMELIER_MEMORY_DOC_ID=your-memory-google-doc-id

# Deployment (used by deploy_and_update.sh)
# ADK paths - adjust based on your environment
ADK_BIN=/path/to/your/venv/bin/adk
ADK_PYTHON=/path/to/your/venv/bin/python3

# Middleware directory (for Firestore updates)
MIDDLEWARE_DIR=/path/to/slack-vertex-ai-middleware

# Agent configuration
AGENT_DISPLAY_NAME=Sam the Som
AGENT_FIRESTORE_ID=your-agent-firestore-document-id

# Staging bucket for ADK deployments
# The deploy script uses: gs://${GOOGLE_CLOUD_PROJECT}-staging
# Create it with: gsutil mb -p ${GOOGLE_CLOUD_PROJECT} -l ${GOOGLE_CLOUD_LOCATION} gs://${GOOGLE_CLOUD_PROJECT}-staging
# Or let the deploy script create it automatically on first run

# Enable Monitoring
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=TRUE
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=TRUE
